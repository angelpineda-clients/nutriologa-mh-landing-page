---
import { floatingWhatsAppCta } from "../../data/landing-content";

import "../../styles/ui/floating-whatsapp-button.css";
---

<a
  class="floating-whatsapp"
  href={floatingWhatsAppCta.href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={floatingWhatsAppCta.ariaLabel}
  data-whatsapp-float
  data-visible="false"
>
  <span class="floating-whatsapp__pulse" aria-hidden="true"></span>
  <span class="floating-whatsapp__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
      <path
        fill="currentColor"
        d="M19.05 4.94A9.77 9.77 0 0 0 12.09 2C6.68 2 2.29 6.39 2.29 11.8c0 1.73.45 3.42 1.31 4.92L2 22l5.43-1.57a9.8 9.8 0 0 0 4.66 1.18h.01c5.4 0 9.79-4.4 9.79-9.8a9.74 9.74 0 0 0-2.84-6.87Zm-6.96 15.01h-.01a8.17 8.17 0 0 1-4.16-1.13l-.3-.18-3.22.93.86-3.14-.2-.32a8.13 8.13 0 0 1-1.26-4.31c0-4.48 3.65-8.13 8.15-8.13a8.1 8.1 0 0 1 5.77 2.39 8.08 8.08 0 0 1 2.37 5.75c0 4.49-3.65 8.14-8.13 8.14Zm4.46-6.09c-.24-.12-1.42-.7-1.64-.78-.22-.08-.38-.12-.54.12-.16.23-.62.78-.76.94-.14.15-.28.17-.52.06a6.62 6.62 0 0 1-1.95-1.2 7.31 7.31 0 0 1-1.35-1.67c-.14-.24-.01-.36.11-.48.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.31-.74-1.79-.2-.47-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.3-.22.24-.85.84-.85 2.06s.87 2.4.99 2.56c.12.16 1.7 2.59 4.12 3.63.58.25 1.03.4 1.39.51.58.18 1.1.16 1.52.1.46-.07 1.42-.58 1.62-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z"
      />
    </svg>
  </span>

  <span class="floating-whatsapp__copy">
    <strong>{floatingWhatsAppCta.label}</strong>
    <span>{floatingWhatsAppCta.helper}</span>
  </span>
</a>

<script>
  const heroShell = document.querySelector("[data-hero-shell]");
  const floatingWhatsApp = document.querySelector("[data-whatsapp-float]");
  const siteFooter = document.querySelector("#footer");

  if (
    heroShell instanceof HTMLElement &&
    floatingWhatsApp instanceof HTMLElement &&
    siteFooter instanceof HTMLElement
  ) {
    let frame = 0;

    const syncVisibility = () => {
      const headerOffset = 96;
      const heroBounds = heroShell.getBoundingClientRect();
      const footerBounds = siteFooter.getBoundingClientRect();
      const footerThreshold = window.innerHeight - 120;
      const hasReachedFooter = footerBounds.top <= footerThreshold;
      const shouldShow = heroBounds.bottom <= headerOffset && !hasReachedFooter;

      floatingWhatsApp.dataset.visible = shouldShow ? "true" : "false";
    };

    const queueVisibilitySync = () => {
      if (frame) {
        return;
      }

      frame = window.requestAnimationFrame(() => {
        syncVisibility();
        frame = 0;
      });
    };

    syncVisibility();
    window.addEventListener("scroll", queueVisibilitySync, { passive: true });
    window.addEventListener("resize", queueVisibilitySync);
  }
</script>
