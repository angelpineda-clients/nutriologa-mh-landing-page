---
import { credentialsPage, professionalProfile } from "../../data/landing-content";
import { getCredentialsMedia } from "../../lib/credentials";
import { Button } from "../ui/Button";
import { CredentialsGallery } from "../ui/CredentialsGallery";
import { Reveal } from "../ui/Reveal";

import "../../styles/sections/credentials-archive.css";

const { documents, portraitImage } = getCredentialsMedia();
---

<section class="credentials section">
  <div class="credentials__veil" aria-hidden="true"></div>
  <div class="shell credentials__shell">
    <Reveal client:visible className="credentials__intro">
      <p class="section-label">{credentialsPage.label}</p>
      <p class="credentials__eyebrow">{credentialsPage.eyebrow}</p>
      <h1 class="section-title credentials__title">{credentialsPage.title}</h1>
      <p class="credentials__body">{credentialsPage.intro.finding}</p>
      <p class="credentials__body">{credentialsPage.intro.intention}</p>

      <div class="credentials__actions">
        <a class="credentials__back-link" href={credentialsPage.primaryCta.href}>
          {credentialsPage.primaryCta.label}
        </a>
        <Button href={credentialsPage.secondaryCta.href} variant="secondary" icon>
          {credentialsPage.secondaryCta.label}
        </Button>
      </div>
    </Reveal>

    <Reveal client:visible className="credentials__portrait-card" delay={0.08} direction="left">
      <div class="credentials__portrait-frame">
        <img
          class="credentials__portrait"
          src={portraitImage}
          alt={credentialsPage.portrait.alt}
          loading="eager"
          width="1080"
          height="1920"
        />
      </div>
    </Reveal>

    <Reveal client:visible className="credentials__archive" delay={0.12}>
      <CredentialsGallery
        client:load
        items={documents}
        labels={credentialsPage.galleryLabels}
      />
    </Reveal>
  </div>
</section>
