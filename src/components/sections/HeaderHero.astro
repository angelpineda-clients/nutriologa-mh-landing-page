---
import { navigation, hero, socialItems } from "../../data/landing-content";
import { Button } from "../ui/Button";
import { Reveal } from "../ui/Reveal";

import "../../styles/sections/header-hero.css";
---

<section class="hero-shell" id="inicio" data-hero-shell>
  <div class="hero-shell__texture"></div>
  <header class="site-header shell" data-site-header>
    <div class="site-header__bar">
      <a class="site-header__brand" href="#inicio">
        <img
          class="site-header__brand-mark"
          src="/favicon.svg"
          alt=""
          width="28"
          height="28"
          aria-hidden="true"
        />
        <span>{hero.brand}</span>
      </a>

      <nav class="site-header__nav" aria-label="Principal">
        <ul>
          {
            navigation.map((item) => (
              <li>
                <a class="site-header__nav-link" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="site-header__actions">
        <Button href={hero.primaryCta.href} className="site-header__cta">Agendar</Button>

        <button
          class="site-header__menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-mobile-menu"
          aria-label="Abrir menú de navegación"
          data-menu-toggle
        >
          <svg
            class="site-header__menu-icon site-header__menu-icon--open"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
          </svg>
          <svg
            class="site-header__menu-icon site-header__menu-icon--close"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="20"
            height="20"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
          </svg>
        </button>
      </div>
    </div>

    <div class="site-header__mobile-menu" id="site-mobile-menu" hidden data-mobile-menu>
      <nav aria-label="Principal móvil">
        <ul class="site-header__mobile-list">
          {
            navigation.map((item) => (
              <li>
                <a class="site-header__mobile-link" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <Button href={hero.primaryCta.href} className="site-header__mobile-cta">
        {hero.primaryCta.label}
      </Button>
    </div>
  </header>

  <div class="hero shell">
    <Reveal client:visible className="hero__content" delay={0.05}>
      <p class="hero__eyebrow">{hero.eyebrow}</p>
      <h1 class="hero__title">{hero.headline}</h1>
      <p class="hero__body">{hero.paragraph}</p>

      <div class="hero__actions">
        <Button href={hero.primaryCta.href}>Agendar</Button>
        <Button href={hero.secondaryCta.href} variant="ghost" className="hero__secondary-action">
          {hero.secondaryCta.label}
        </Button>
      </div>
    </Reveal>

    <Reveal client:visible className="hero__media" delay={0.12} direction="left">
      <div class="hero__portrait-frame">
        <img
          class="hero__portrait"
          src="/images/hero-portrait.webp"
          alt="Retrato de Monserrat Herrera, nutrióloga clínica"
          loading="eager"
          fetchpriority="high"
          width="2268"
          height="4032"
        />
      </div>

      <div class="hero__social-stack">
        <p class="hero__social-kicker">Sígueme</p>
        <ul class="hero__socials" aria-label="Redes sociales">
          {
            socialItems.map((item) => (
              <li>
                <a
                  class="hero__social-chip"
                  href={item.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={item.ariaLabel}
                  data-platform={item.platform}
                  title={item.label}
                >
                  <span class="hero__social-icon" aria-hidden="true">
                    {item.platform === "instagram" ? (
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" focusable="false">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                      </svg>
                    ) : (
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" focusable="false">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.19 8.19 0 004.78 1.52V6.79a4.84 4.84 0 01-1.01-.1z"/>
                      </svg>
                    )}
                  </span>
                  <span class="sr-only">{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </Reveal>
  </div>
</section>

<script>
  const header = document.querySelector("[data-site-header]");
  const menuToggle = document.querySelector("[data-menu-toggle]");
  const mobileMenu = document.querySelector("[data-mobile-menu]");
  const mobileLinks = mobileMenu?.querySelectorAll("a");

  if (header instanceof HTMLElement) {
    const syncScrollState = () => {
      header.classList.toggle("site-header--scrolled", window.scrollY > 18);
    };

    syncScrollState();
    window.addEventListener("scroll", syncScrollState, { passive: true });
  }

  if (
    header instanceof HTMLElement &&
    menuToggle instanceof HTMLButtonElement &&
    mobileMenu instanceof HTMLElement
  ) {
    let hideMenuTimeout = 0;
    const menuTransitionMs = 220;

    const clearHideTimeout = () => {
      window.clearTimeout(hideMenuTimeout);
    };

    const closeMenu = ({ immediate = false } = {}) => {
      clearHideTimeout();
      header.dataset.menuOpen = "false";
      menuToggle.setAttribute("aria-expanded", "false");
      menuToggle.setAttribute("aria-label", "Abrir menú de navegación");

      if (immediate) {
        mobileMenu.hidden = true;
        return;
      }

      hideMenuTimeout = window.setTimeout(() => {
        mobileMenu.hidden = true;
      }, menuTransitionMs);
    };

    const openMenu = () => {
      clearHideTimeout();
      mobileMenu.hidden = false;

      window.requestAnimationFrame(() => {
        header.dataset.menuOpen = "true";
      });
      menuToggle.setAttribute("aria-expanded", "true");
      menuToggle.setAttribute("aria-label", "Cerrar menú de navegación");
    };

    menuToggle.addEventListener("click", () => {
      const isOpen = header.dataset.menuOpen === "true";
      if (isOpen) {
        closeMenu();
        return;
      }

      openMenu();
    });

    mobileLinks?.forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth > 640) {
        closeMenu({ immediate: true });
      }
    });

    closeMenu({ immediate: true });
  }
</script>
