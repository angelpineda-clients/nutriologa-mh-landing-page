---
import { specialties, whatsappConsultationCta } from "../../data/landing-content";
import { Reveal } from "../ui/Reveal";

import "../../styles/sections/specialties.css";
---

<section class="specialties section" id="especialidades">
  <div class="shell">
    <Reveal client:visible className="specialties__intro">
      <p class="section-label">Temas de especialidad</p>
      <h2 class="section-title">Podemos trabajar en...</h2>
      <p class="specialties__lead">
        Si recibiste un diagnóstico, tienes síntomas digestivos o quieres una
        evaluación nutricia integral, estos son algunos de los temas que podemos
        revisar.
      </p>
    </Reveal>

    <Reveal client:visible className="specialties__cards" delay={0.06}>
      {
        specialties.map((topic) =>
          topic.label === "Otro*" ? (
            <a
              class="specialties__card specialties__card--cta"
              href={whatsappConsultationCta.href}
              target="_blank"
              rel="noopener noreferrer"
              title="Cuéntame tu caso por WhatsApp"
            >
              <span class="specialties__card-icon" aria-hidden="true">{topic.icon}</span>
              <h3 class="specialties__card-title">¿Otro tema?</h3>
              <p class="specialties__card-body">
                Cuéntame tu caso — trabajamos juntas en lo que necesitas.
              </p>
            </a>
          ) : (
            <div class="specialties__card">
              <span class="specialties__card-icon" aria-hidden="true">{topic.icon}</span>
              <h3 class="specialties__card-title">{topic.label}</h3>
              <p class="specialties__card-body">{topic.description}</p>
            </div>
          )
        )
      }
    </Reveal>
  </div>
</section>
