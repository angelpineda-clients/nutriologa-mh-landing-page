---
import { processCta, processSteps } from "../../data/landing-content";
import { Button } from "../ui/Button";
import { Reveal } from "../ui/Reveal";
import { ProcessStepList } from "../ui/ProcessStepList";

import "../../styles/sections/process.css";
---

<section class="process section" id="proceso">
  <div class="shell process__inner">
    <Reveal client:visible className="process__heading">
      <h2 class="section-title process__title">¿Cómo será nuestro proceso?</h2>
    </Reveal>

    <div class="process__grid">
      <Reveal client:visible className="process__art" delay={0.06}>
        <div class="process__art-frame">
          <img
            class="process__image"
            src="/images/process.webp"
            alt=""
            loading="lazy"
            width="2268"
            height="4032"
          />
        </div>
      </Reveal>

      <div class="process__steps">
        <ProcessStepList client:visible steps={processSteps} />

        <Reveal client:visible delay={0.7}>
          <div class="process__cta-wrap">
            <p class="process__cta-intro">{processCta.intro}</p>
            <Button href={processCta.button.href} className="process__cta">
              {processCta.button.label}
            </Button>
          </div>
        </Reveal>
      </div>
    </div>
  </div>
</section>
