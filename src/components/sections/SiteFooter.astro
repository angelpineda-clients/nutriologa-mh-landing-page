---
import {
  appointmentBookingHref,
  footerLinks,
  hero,
  professionalProfile,
  socialItems,
  whatsappConsultationCta
} from "../../data/landing-content";
import { Button } from "../ui/Button";

import "../../styles/sections/footer.css";

type Props = {
  homeHrefBase?: string;
};

const { homeHrefBase = "" } = Astro.props;

const toHomeHref = (href: string) => {
  if (!href.startsWith("#")) {
    return href;
  }

  return `${homeHrefBase}${href}`;
};
---

<footer class="site-footer" id="footer">
  <div class="shell site-footer__inner">
    <div class="site-footer__brand-block">
      <p class="site-footer__heading">NUTRICIÓN CON CONEXIÓN</p>
      <a class="site-footer__brand" href={toHomeHref("#inicio")}>{hero.brand}</a>
      <p class="site-footer__summary">
        Nutrióloga clínica con consulta en línea y enfoque gentil para salud
        digestiva, metabólica y cambio de hábitos.
        Consultas en línea para pacientes en México.
      </p>
      <p class="site-footer__cedula">
        Cédula Profesional SEP: <strong>{professionalProfile.cedulaProfesional}</strong>
        &nbsp;·&nbsp; {professionalProfile.city}
      </p>
      <ul class="site-footer__contact-list">
        <li>
          <a
            class="site-footer__contact-link"
            href={whatsappConsultationCta.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="site-footer__contact-icon site-footer__contact-icon--whatsapp" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false" fill="currentColor">
                <path
                  d="M19.05 4.94A9.77 9.77 0 0 0 12.09 2C6.68 2 2.29 6.39 2.29 11.8c0 1.73.45 3.42 1.31 4.92L2 22l5.43-1.57a9.8 9.8 0 0 0 4.66 1.18h.01c5.4 0 9.79-4.4 9.79-9.8a9.74 9.74 0 0 0-2.84-6.87Zm-6.96 15.01h-.01a8.17 8.17 0 0 1-4.16-1.13l-.3-.18-3.22.93.86-3.14-.2-.32a8.13 8.13 0 0 1-1.26-4.31c0-4.48 3.65-8.13 8.15-8.13a8.1 8.1 0 0 1 5.77 2.39 8.08 8.08 0 0 1 2.37 5.75c0 4.49-3.65 8.14-8.13 8.14Zm4.46-6.09c-.24-.12-1.42-.7-1.64-.78-.22-.08-.38-.12-.54.12-.16.23-.62.78-.76.94-.14.15-.28.17-.52.06a6.62 6.62 0 0 1-1.95-1.2 7.31 7.31 0 0 1-1.35-1.67c-.14-.24-.01-.36.11-.48.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.54-1.31-.74-1.79-.2-.47-.4-.41-.54-.42h-.46c-.16 0-.42.06-.64.3-.22.24-.85.84-.85 2.06s.87 2.4.99 2.56c.12.16 1.7 2.59 4.12 3.63.58.25 1.03.4 1.39.51.58.18 1.1.16 1.52.1.46-.07 1.42-.58 1.62-1.14.2-.56.2-1.04.14-1.14-.06-.1-.22-.16-.46-.28Z"
                />
              </svg>
            </span>
            <span class="site-footer__contact-copy">
              <span class="site-footer__contact-platform">WhatsApp</span>
            </span>
          </a>
        </li>
        {
          socialItems.map((item) => (
            <li>
              <a
                class="site-footer__contact-link"
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={item.ariaLabel}
                data-platform={item.platform}
              >
                <span class="site-footer__contact-icon" aria-hidden="true">
                  {item.platform === "instagram" ? (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" focusable="false">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                  ) : (
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" focusable="false">
                      <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.75a8.19 8.19 0 004.78 1.52V6.79a4.84 4.84 0 01-1.01-.1z"/>
                    </svg>
                  )}
                </span>
                <span class="site-footer__contact-copy">
                  <span class="site-footer__contact-platform">{item.label}</span>
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="site-footer__nav-block">
      <p class="site-footer__heading">Navegación</p>
      <ul>
        {
          footerLinks.map((item) => (
            <li>
              <a href={toHomeHref(item.href)}>{item.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="site-footer__cta-block">
      <p class="site-footer__heading">Consulta en línea</p>
      <p class="site-footer__cta-copy">
        Si quieres dar el siguiente paso, agenda tu primera consulta y comencemos a revisar tu
        caso.
      </p>
      <Button href={appointmentBookingHref}>Agendar</Button>
    </div>
  </div>
  <p class="site-footer__copyright shell">© 2026 Monserrat Herrera · Todos los derechos reservados.</p>
</footer>
