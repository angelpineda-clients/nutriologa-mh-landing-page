---
import GroupsRoundedIcon from "@mui/icons-material/GroupsRounded";
import SchoolRoundedIcon from "@mui/icons-material/SchoolRounded";
import VideocamRoundedIcon from "@mui/icons-material/VideocamRounded";

import { services, type Service } from "../../data/landing-content";
import { Button } from "../ui/Button";
import { Reveal } from "../ui/Reveal";

import "../../styles/sections/services.css";

const serviceIcons: Record<Service["icon"], typeof VideocamRoundedIcon> = {
  videocam: VideocamRoundedIcon,
  groups: GroupsRoundedIcon,
  school: SchoolRoundedIcon
};
---

<section class="services section" id="servicios">
  <div class="shell">
    <Reveal client:visible className="services__intro">
      <p class="section-label">Servicios</p>
      <h2 class="section-title">Formas en las que puedo acompañarte</h2>
      <p class="services__lead">
        Cada servicio responde a una necesidad distinta, pero todos parten de una
        nutrición más humana, clara y sostenible.
      </p>
    </Reveal>

    <div class="services__grid">
      {
        services.map((service, index) => {
          const Icon = serviceIcons[service.icon];

          return (
            <Reveal
              client:visible
              className={["service-card", service.featured ? "service-card--featured" : ""]
                .filter(Boolean)
                .join(" ")}
              delay={0.04 * index}
              direction="up"
            >
              <div class="service-card__header">
                <div class="service-card__icon" aria-hidden="true">
                  <Icon />
                </div>
              </div>

              <div class="service-card__content">
                <h3 class="service-card__title">{service.title}</h3>
                <p class="service-card__description">{service.description}</p>
              </div>

              <div class="service-card__footer">
                <Button
                  href={service.href}
                  className="service-card__cta"
                  variant={index === 0 ? "primary" : "secondary"}
                >
                  {service.cta}
                </Button>
              </div>
            </Reveal>
          );
        })
      }
    </div>
  </div>
</section>
