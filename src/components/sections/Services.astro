---
import { services } from "../../data/landing-content";
import { Button } from "../ui/Button";
import { Reveal } from "../ui/Reveal";

import "../../styles/sections/services.css";
---

<section class="services section" id="servicios">
  <div class="shell">
    <Reveal client:visible className="services__intro">
      <p class="section-label">Servicios</p>
      <h2 class="section-title">Formas en las que puedo acompañarte</h2>
      <p class="services__lead">
        Cada servicio responde a una necesidad distinta, pero todos parten de una
        nutrición más humana, clara y sostenible.
      </p>
    </Reveal>

    <div class="services__grid">
      {
        services.map((service, index) => (
        <Reveal
          client:visible
          className={["service-card", index === 1 ? "service-card--accent" : ""]
            .filter(Boolean)
            .join(" ")}
          delay={0.04 * index}
          direction="up"
        >
            <div class="service-card__ornament"></div>
            <h3 class="service-card__title">{service.title}</h3>
            <p class="service-card__description">{service.description}</p>
            <Button
              href={service.href}
              className="service-card__cta"
              variant={index === 0 ? "primary" : "secondary"}
            >
              {service.cta}
            </Button>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
