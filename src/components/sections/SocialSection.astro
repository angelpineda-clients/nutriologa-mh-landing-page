---
import InstagramIcon from "@mui/icons-material/Instagram";
import { faTiktok } from "@fortawesome/free-brands-svg-icons";
import { FontAwesomeIcon } from "@fortawesome/react-fontawesome";

import { socialItems } from "../../data/landing-content";
import { Reveal } from "../ui/Reveal";

import "../../styles/sections/social.css";
---

<section class="social section" id="social">
  <div class="shell social__panel">
    <Reveal client:visible className="social__intro">
      <h2 class="section-title social__title">Más ideas y recursos en mis redes</h2>
      <p class="social__lead">
        Encuentra contenido cercano, educativo y práctico para seguir construyendo
        bienestar fuera de consulta.
      </p>
    </Reveal>

    <Reveal client:visible className="social__icons" delay={0.06}>
      <p class="social__icons-label">Sígueme</p>
      <div class="social__icons-tray" aria-label="Redes sociales">
        {
          socialItems.map((item) => (
            <a
              class="social__icon-chip"
              href={item.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={item.ariaLabel}
              data-platform={item.platform}
              title={item.label}
            >
              <span class="social__icon-mark" aria-hidden="true">
                {item.platform === "instagram" ? <InstagramIcon /> : <FontAwesomeIcon icon={faTiktok} />}
              </span>
              <span class="sr-only">{item.label}</span>
            </a>
          ))
        }
      </div>
    </Reveal>
  </div>
</section>
