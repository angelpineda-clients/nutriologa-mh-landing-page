---
import HeaderHero from "../components/sections/HeaderHero.astro";
import Philosophy from "../components/sections/Philosophy.astro";
import ProcessSection from "../components/sections/ProcessSection.astro";
import Services from "../components/sections/Services.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import Specialties from "../components/sections/Specialties.astro";
import FaqSection from "../components/sections/FaqSection.astro";
import ClosingCta from "../components/sections/ClosingCta.astro";
import SocialSection from "../components/sections/SocialSection.astro";
import SiteFooter from "../components/sections/SiteFooter.astro";
import FloatingWhatsAppButton from "../components/ui/FloatingWhatsAppButton.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildHomeStructuredData, siteMeta } from "../data/landing-content";

const homeStructuredData = buildHomeStructuredData();
---

<BaseLayout
  title={siteMeta.title}
  description={siteMeta.description}
  pathname="/"
  image={siteMeta.image}
  structuredData={homeStructuredData}
  preloadImageHref="/images/hero-portrait.webp"
>
  <main class="page">
    <HeaderHero />
    <Philosophy />
    <ProcessSection />
    <Services />
    <Testimonials />
    <Specialties />
    <FaqSection />
    <ClosingCta />
    <SocialSection />
  </main>
  <FloatingWhatsAppButton />
  <SiteFooter />
</BaseLayout>
