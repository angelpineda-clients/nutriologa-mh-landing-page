---
import "../styles/global.css";
import SpeedInsights from "@vercel/speed-insights/astro";
import { siteMeta } from "../data/landing-content";

type Props = {
  title: string;
  description: string;
  pathname?: string;
  image?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  noindex?: boolean;
  preloadImageHref?: string;
};

const {
  title,
  description,
  pathname = "/",
  image = siteMeta.image,
  structuredData,
  noindex = false,
  preloadImageHref
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "");
const canonical = siteUrl ? new URL(pathname, siteUrl).toString() : undefined;
const socialImage = image
  ? /^https?:\/\//i.test(image)
    ? image
    : siteUrl
      ? new URL(image, siteUrl).toString()
      : image
  : undefined;
const robots = noindex ? "noindex, nofollow" : "index, follow";
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const structuredDataBlocks = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {preloadImageHref ? <link rel="preload" as="image" href={preloadImageHref} fetchpriority="high" /> : null}
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={robots} />
    <meta name="theme-color" content="#fdf8f1" />
    {googleSiteVerification ? <meta name="google-site-verification" content={googleSiteVerification} /> : null}
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:locale" content={siteMeta.locale} />
    <meta property="og:type" content={siteMeta.type} />
    <meta property="og:site_name" content={siteMeta.siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonical ? <meta property="og:url" content={canonical} /> : null}
    {socialImage ? <meta property="og:image" content={socialImage} /> : null}
    {socialImage ? <meta property="og:image:alt" content={title} /> : null}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage ? <meta name="twitter:image" content={socialImage} /> : null}
    <title>{title}</title>
    {
      structuredDataBlocks.map((entry) => (
        <script type="application/ld+json" set:html={JSON.stringify(entry)} />
      ))
    }
    <SpeedInsights />
  </head>
  <body>
    <slot />
  </body>
</html>
